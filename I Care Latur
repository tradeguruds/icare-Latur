<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>I Care Latur | Apple Products Repair Specialist</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:#000;
color:#fff;
}

header{
background:#000;
padding:20px;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
z-index:100;
border-bottom:1px solid #222;
}

.logo{
font-size:30px;
font-weight:bold;
color:white;
}

.logo span{
color:red;
}

nav a{
color:white;
text-decoration:none;
margin:15px;
font-size:16px;
}

.hero{

height:90vh;

display:flex;
flex-direction:column;

justify-content:center;

align-items:center;

text-align:center;

background:linear-gradient(rgba(0,0,0,.75),rgba(0,0,0,.75)),
url("https://images.unsplash.com/photo-1511707171634-5f897ff02aa9") center/cover;
}

.hero h1{

font-size:55px;

margin-bottom:20px;

}

.hero span{

color:red;

}

.hero p{

font-size:20px;

margin-bottom:25px;

}

.btn{

background:red;

padding:15px 35px;

text-decoration:none;

color:white;

border-radius:30px;

font-weight:bold;

}

section{

padding:70px 10%;

}

.title{

text-align:center;

font-size:40px;

margin-bottom:40px;

color:red;

}

.services{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

gap:30px;

}

.card{

background:#111;

padding:30px;

border-radius:15px;

text-align:center;

transition:.4s;

}

.card:hover{

transform:translateY(-10px);

background:#181818;

}

.card h3{

color:red;

margin-bottom:15px;

}

.booking{

background:#111;

border-radius:20px;

padding:30px;

max-width:700px;

margin:auto;

}

.booking input,

.booking select,

.booking textarea{

width:100%;

padding:15px;

margin:10px 0;

border:none;

border-radius:8px;

}

.booking button{

background:red;

color:white;

padding:15px;

width:100%;

border:none;

border-radius:10px;

font-size:18px;

cursor:pointer;

}

.contact{

text-align:center;

line-height:2;

font-size:18px;

}

footer{

background:#111;

padding:30px;

text-align:center;

}

@media(max-width:768px){

.hero h1{

font-size:36px;

}

nav{

display:none;

}

}

</style>

</head>

<body>

<header>

<div class="logo">I <span>Care</span> Latur</div>

<nav>

<a href="#">Home</a>

<a href="#services">Services</a>

<a href="#booking">Booking</a>

<a href="#contact">Contact</a>

</nav>

</header>

<section class="hero">

<h1>Apple Products <span>Repair</span> Specialist</h1>

<p>Professional Repair • Genuine Parts • Expert Technicians</p>

<a href="#booking" class="btn">Book Repair Slot</a>

</section>

<section id="services">

<h2 class="title">Repair Categories</h2>

<div class="services">

<div class="card">
<h3>iPhone Repair</h3>
<p>Display, Battery, Camera, Charging, Face ID, Water Damage</p>
</div>

<div class="card">
<h3>MacBook Repair</h3>
<p>Logic Board, Keyboard, Display, SSD, Battery</p>
</div>

<div class="card">
<h3>iPad Repair</h3>
<p>Touch, LCD, Battery, Charging Port</p>
</div>

<div class="card">
<h3>Apple Watch</h3>
<p>Display, Battery, Diagnostics</p>
</div>

<div class="card">
<h3>AirPods</h3>
<p>Battery Replacement & Repair</p>
</div>

<div class="card">
<h3>Data Recovery</h3>
<p>Professional Data Recovery Services</p>
</div>

</div>

</section>

<section id="booking">

<h2 class="title">Book Repair Slot</h2>

<div class="booking">

<form onsubmit="sendWhatsapp();return false;">

<input type="text" id="name" placeholder="Your Name" required>

<input type="tel" id="phone" placeholder="Mobile Number" required>

<select id="device">

<option>iPhone</option>

<option>MacBook</option>

<option>iPad</option>

<option>Apple Watch</option>

<option>AirPods</option>

</select>

<input type="text" id="model" placeholder="Device Model">

<textarea id="problem" placeholder="Describe Problem"></textarea>

<button>Book on WhatsApp</button>

</form>

</div>

</section>

<section id="contact">

<h2 class="title">Visit Us</h2>

<div class="contact">

📍 In Front of D-Mart, Latur, Maharashtra

<br><br>

📞 +91 8446722671

<br><br>

Open Every Day

9:30 AM - 9:00 PM

</div>

</section>

<footer>

© 2026 I Care Latur

<br>

Apple Products Repair Specialist

</footer>

<script>

function sendWhatsapp(){

let name=document.getElementById("name").value;

let phone=document.getElementById("phone").value;

let device=document.getElementById("device").value;

let model=document.getElementById("model").value;

let problem=document.getElementById("problem").value;

let message=`*Repair Slot Booking*%0A%0AName: ${name}%0APhone: ${phone}%0ADevice: ${device}%0AModel: ${model}%0AProblem: ${problem}`;

window.open("https://wa.me/918446722671?text="+message);

}

</script>

</body>

</html>
